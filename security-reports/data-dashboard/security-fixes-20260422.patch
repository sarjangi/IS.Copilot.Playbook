From a25762200c0ba137b42b7df99e4c50f0db9b942e Mon Sep 17 00:00:00 2001
From: Copilot Security Bot <security-bot@copilot>
Date: Wed, 22 Apr 2026 18:31:23 +0000
Subject: [PATCH] security: upgrade vulnerable dependencies
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- fastapi 0.115.0 → 0.136.0 (pulls in Starlette ≥0.40.0 fixing CVE-2024-47874 and CVE-2025-54121)
- python-multipart 0.0.12 → 0.0.26 (fixes CVE-2024-53981, CVE-2026-24486, CVE-2026-40347)
- python-jose 3.3.0 → 3.4.0 (fixes PYSEC-2024-232 algorithm confusion, PYSEC-2024-233 JWE DoS)
- python-dotenv 1.0.1 → 1.2.2 (fixes CVE-2026-28684 symlink traversal)
- pytest 8.3.4 → 9.0.3 (fixes CVE-2025-71176 predictable temp dir)
- black 24.10.0 → 26.3.1 (fixes CVE-2026-32274 cache path injection)
- docker-compose.yml: add warning comment on default POSTGRES_PASSWORD
---
 backend/docker-compose.yml |  2 ++
 backend/requirements.txt   | 12 ++++++------
 2 files changed, 8 insertions(+), 6 deletions(-)

diff --git a/backend/docker-compose.yml b/backend/docker-compose.yml
index 0ebaa81..6350b27 100644
--- a/backend/docker-compose.yml
+++ b/backend/docker-compose.yml
@@ -7,6 +7,8 @@ services:
     environment:
       POSTGRES_DB: analytics
       POSTGRES_USER: analytics
+      # WARNING: Change this password before deploying to any non-local environment.
+      # Use a strong, randomly generated password via an environment variable or secrets manager.
       POSTGRES_PASSWORD: analytics123
     ports:
       - "5432:5432"
diff --git a/backend/requirements.txt b/backend/requirements.txt
index 7e604bf..6aa42da 100644
--- a/backend/requirements.txt
+++ b/backend/requirements.txt
@@ -1,7 +1,7 @@
 # FastAPI and Server
-fastapi==0.115.0
+fastapi==0.136.0
 uvicorn[standard]==0.32.0
-python-multipart==0.0.12
+python-multipart==0.0.26
 
 # Database
 sqlalchemy[asyncio]==2.0.36
@@ -21,9 +21,9 @@ pydantic-settings==2.6.1
 email-validator==2.2.0
 
 # CORS and Security
-python-jose[cryptography]==3.3.0
+python-jose[cryptography]==3.4.0
 passlib[bcrypt]==1.7.4
-python-dotenv==1.0.1
+python-dotenv==1.2.2
 
 # Scheduling
 apscheduler==3.10.4
@@ -36,11 +36,11 @@ reportlab==4.2.5
 httpx==0.28.0
 
 # Testing
-pytest==8.3.4
+pytest==9.0.3
 pytest-asyncio==0.24.0
 pytest-cov==6.0.0
 
 # Development
-black==24.10.0
+black==26.3.1
 ruff==0.8.4
 mypy==1.13.0
-- 
2.53.0

